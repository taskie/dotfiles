#!/bin/sh
set -u

PROGRAM_NAME="$(basename "$0")"

usage () {
    cat <<EOF
${PROGRAM_NAME}

Usage:
    ${PROGRAM_NAME} PATTERN REPLACEMENT_TEXT [RG_ARGS...]
EOF
}

if [ $# -lt 2 ]; then
    usage >&2
    exit 1
fi

pat="$1"
rep="$2"
shift 2

{{if .nablex}}
rg -l0 "$pat" "$@" | nablex -f - -0u rg "$pat" -r "$rep" -IN --passthru
{{else if .parallel}}
rg -l0 "$pat" "$@" | parallel -n 1 -0qr bash -c 'diff -u --label "$3" --label "$3" "$3" <(rg "$1" --replace "$2" -IN --passthru "$3") || :' _ "$pat" "$rep"
{{else}}
rg -l0 "$pat" "$@" | xargs -n 1 -0r bash -c 'diff -u --label "$3" --label "$3" "$3" <(rg "$1" --replace "$2" -IN --passthru "$3") || :' _ "$pat" "$rep"
{{end}}
