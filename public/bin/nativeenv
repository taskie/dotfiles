#!/bin/sh
export CFLAGS="${CFLAGS} -march=native -mtune=native -O2 -pipe -fno-plt -fexceptions -Wp,-D_FORTIFY_SOURCE=3 -Wformat -Werror=format-security -fstack-clash-protection -fcf-protection -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer"
export CXXFLAGS="${CFLAGS} ${CXXFLAGS} -Wp,-D_GLIBCXX_ASSERTIONS"
export RUSTFLAGS="${RUSTFLAGS} -C target-cpu=native"
export LDFLAGS="${LDFLAGS} -Wl,-O1 -Wl,--sort-common -Wl,--as-needed -Wl,-z,relro -Wl,-z,now -Wl,-z,pack-relative-relocs"
export LTOFLAGS="${LTOFLAGS} -flto=auto"
export RUSTFLAGS="${RUSTFLAGS} -C opt-level=2 -C target-cpu=native"

if [ $# -ge 1 ]; then
  exec "$@"
fi
